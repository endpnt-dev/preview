# Upstash Redis for rate limiting
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# API keys configuration (JSON format)
API_KEYS={"ek_live_EXAMPLE_REPLACE_ME":{"tier":"free","name":"Demo Key"},"ek_your_key_here":{"tier":"starter","name":"Your App"}}

# Site URL for meta tags and redirects
NEXT_PUBLIC_SITE_URL=https://preview.endpnt.dev